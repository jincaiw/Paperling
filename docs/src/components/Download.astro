---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import sceneCelebration from "../assets/scenes/scene-celebration.png";
const releases = "https://github.com/Razee4315/Paperling/releases/latest";
const repo = "https://github.com/Razee4315/Paperling";

const platforms = [
  {
    icon: "simple-icons:windows10",
    os: "Windows",
    note: "Windows 10 / 11 (64-bit).",
    formats: ".exe installer · .msi",
    href: releases,
    cta: "Download for Windows",
    primary: true,
  },
  {
    icon: "simple-icons:linux",
    os: "Linux",
    note: "Debian/Ubuntu, Fedora, or any distro via AppImage.",
    formats: ".deb · .rpm · .AppImage",
    href: releases,
    cta: "Download for Linux",
    primary: true,
  },
  {
    icon: "simple-icons:apple",
    os: "macOS",
    note: "No prebuilt binary yet. Build from source in a couple of commands.",
    formats: "Tauri supports macOS. Help us ship a build!",
    href: `${repo}#development`,
    cta: "Build from source",
    primary: false,
  },
];
---

<section id="download" class="relative overflow-hidden py-24 md:py-32">
  <div class="aurora" style="opacity:.3;height:60vh" data-parallax="5"></div>
  <div class="relative z-10 mx-auto max-w-6xl px-5">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <p class="mono-label justify-center"><span class="tok-mark">$</span> download</p>
      <h2 class="font-serif-display mt-3 text-[clamp(2.4rem,6vw,4rem)]">
        Get Paperling. It's free.
      </h2>
      <p class="mt-4 text-lg text-fg-muted">
        Free and open source. Grab the latest release for your platform. No account required.
      </p>
    </div>

    <!-- Confetti send-off: the mascot celebrating your download decision.
         Shown UNCROPPED: the scene's own paper background blends with the page. -->
    <div class="mx-auto mt-10 max-w-3xl" data-reveal>
      <Image
        src={sceneCelebration}
        alt="The Paperling mascot jumping with confetti and paper planes"
        widths={[760, 1100, 1600]}
        sizes="(max-width: 1024px) 100vw, 768px"
        loading="lazy"
        class="w-full rounded-2xl border border-line"
      />
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {platforms.map((p) => (
        <article class="card flex flex-col p-7" data-reveal>
          <div class="flex items-center gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-line text-fg">
              <Icon name={p.icon} class="h-5 w-5" />
            </span>
            <h3 class="text-xl font-semibold">{p.os}</h3>
          </div>
          <p class="mt-4 flex-1 text-[15px] text-fg-muted">{p.note}</p>
          <a
            href={p.href}
            rel="noopener"
            class={`btn mt-6 w-full justify-center ${p.primary ? "btn-primary" : "btn-ghost"}`}
          >
            {p.cta}
          </a>
          <p class="mt-3 text-center text-xs text-fg-dim">{p.formats}</p>
        </article>
      ))}
    </div>
  </div>
</section>
