---
import { Icon } from "astro-icon/components";
const items = [
  { icon: "lucide:wifi-off", label: "Works fully offline" },
  { icon: "lucide:eye-off", label: "No telemetry, ever" },
  { icon: "lucide:cpu", label: "Native — Tauri + Rust" },
  { icon: "lucide:git-fork", label: "Open source" },
  { icon: "lucide:bot", label: "Bring your own AI model" },
];
---

<section class="border-y border-line-soft bg-ink-950/60">
  <div
    class="mx-auto flex max-w-6xl flex-wrap items-center justify-center gap-x-8 gap-y-3 px-5 py-6 text-sm text-fg-dim"
    data-reveal
  >
    {items.map((it) => (
      <span class="inline-flex items-center gap-2">
        <Icon name={it.icon} class="h-4 w-4 text-fg-muted" />
        {it.label}
      </span>
    ))}
  </div>
</section>
