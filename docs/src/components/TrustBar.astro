---
// A slim status-bar strip, set like the bottom bar of a code editor.
// Reinforces the "the page is an editor" motif instead of a logo-soup trust row.
const items = [
  "Markdown",
  "UTF-8",
  "Windows + Linux",
  "no account",
  "no telemetry",
  "100% offline",
  "Apache-2.0",
];
---

<section class="border-y border-line-soft bg-ink-950/70">
  <div
    class="mx-auto flex max-w-6xl flex-wrap items-center gap-x-5 gap-y-2 px-5 py-3 font-mono text-[12px] text-fg-dim"
    data-reveal
  >
    <span class="flex items-center gap-2 text-fg-muted">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-ok)]"></span>
      Ln 1, Col 1
    </span>
    {items.map((it) => (
      <>
        <span class="text-fg-dim/40">·</span>
        <span>{it}</span>
      </>
    ))}
  </div>
</section>
