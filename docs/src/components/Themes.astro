---
import { Image } from "astro:assets";
import AppWindow from "./AppWindow.astro";
import readerDark from "../assets/screenshots/reader-dark.png";
import readerLight from "../assets/screenshots/reader-light.png";
import readerPaper from "../assets/screenshots/reader-paper.png";
import readerGithub from "../assets/screenshots/reader-github.png";

const themes = [
  { id: "dark", label: "Dark", img: readerDark, swatch: ["#0a0a0d", "#ffffff"] },
  { id: "light", label: "Light", img: readerLight, swatch: ["#ffffff", "#171717"] },
  { id: "paper", label: "Paper", img: readerPaper, swatch: ["#f5f0e6", "#5c4033"] },
  { id: "github", label: "GitHub", img: readerGithub, swatch: ["#ffffff", "#0969da"] },
];
---

<section id="themes" class="relative py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-5">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <p class="eyebrow justify-center">Themes &amp; typography</p>
      <h2 class="mt-3 text-4xl font-extrabold tracking-tight md:text-5xl">
        Four themes. Five fonts. Your call.
      </h2>
      <p class="mt-4 text-lg text-fg-muted">
        Dark, Light, Paper, and a pixel-accurate GitHub theme, plus focus and typewriter modes for
        when you really need to think.
      </p>
    </div>

    <div class="mt-10 flex flex-wrap justify-center gap-2" data-reveal data-theme-tabs>
      {themes.map((t, i) => (
        <button
          type="button"
          data-theme-tab={t.id}
          aria-pressed={i === 0 ? "true" : "false"}
          class="group inline-flex items-center gap-2 rounded-full border border-line px-4 py-2 text-sm text-fg-muted transition-colors hover:text-fg aria-pressed:border-brand/60 aria-pressed:bg-brand/10 aria-pressed:text-fg"
        >
          <span class="flex h-4 w-4 overflow-hidden rounded-full border border-white/20">
            <span class="h-full w-1/2" style={`background:${t.swatch[0]}`}></span>
            <span class="h-full w-1/2" style={`background:${t.swatch[1]}`}></span>
          </span>
          {t.label}
        </button>
      ))}
    </div>

    <div class="relative mx-auto mt-8 max-w-5xl" data-reveal>
      <AppWindow label="Getting Started.md, Reader">
        <div class="relative aspect-[1920/1030] w-full bg-ink-900">
          {themes.map((t, i) => (
            <Image
              src={t.img}
              alt={`MarkLite ${t.label} theme rendering a Markdown document`}
              widths={[760, 1100, 1600]}
              sizes="(max-width: 1024px) 100vw, 1024px"
              loading="lazy"
              data-theme-panel={t.id}
              class={`absolute inset-0 h-full w-full object-cover object-top transition-opacity duration-500 ${
                i === 0 ? "opacity-100" : "opacity-0"
              }`}
            />
          ))}
        </div>
      </AppWindow>
    </div>
  </div>
</section>

<script>
  const root = document.querySelector<HTMLElement>("[data-theme-tabs]");
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-theme-tab]"));
  const panels = Array.from(document.querySelectorAll<HTMLElement>("[data-theme-panel]"));
  let active = 0;
  let timer: number | undefined;
  let userTouched = false;

  function show(i: number) {
    active = (i + tabs.length) % tabs.length;
    tabs.forEach((t, n) => t.setAttribute("aria-pressed", n === active ? "true" : "false"));
    panels.forEach((p, n) => {
      p.classList.toggle("opacity-100", n === active);
      p.classList.toggle("opacity-0", n !== active);
    });
  }

  tabs.forEach((t, i) =>
    t.addEventListener("click", () => {
      userTouched = true;
      window.clearInterval(timer);
      show(i);
    }),
  );

  // Gentle auto-cycle until the visitor takes over
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!reduce && root) {
    timer = window.setInterval(() => {
      if (!userTouched) show(active + 1);
    }, 3200);
  }
</script>
