---
import { Image } from "astro:assets";
import iconSparkles from "../assets/mascot/icon-sparkles.png";
import iconSplitView from "../assets/mascot/icon-split-view.png";
import iconMath from "../assets/mascot/icon-math.png";
import iconDiagram from "../assets/mascot/icon-diagram.png";
import iconSlash from "../assets/mascot/icon-slash.png";
import iconLinkPages from "../assets/mascot/icon-link-pages.png";
import iconPalette from "../assets/mascot/icon-command-palette.png";
import iconMoonSun from "../assets/mascot/icon-moon-sun.png";
import iconBolt from "../assets/mascot/icon-bolt.png";

const rows = [
  {
    img: iconSparkles,
    title: "AI: Ask & Agent",
    desc: "Chat about your document, or let Agent propose edits as an inline diff you accept or reject. Bring your own model.",
    kbd: "Agent",
    accent: "cyan",
  },
  {
    img: iconSplitView,
    title: "Reader · Code · Split",
    desc: "Rendered reading, raw source, or both side by side with bidirectional scroll sync.",
    kbd: "Ctrl+\\",
  },
  {
    img: iconMath,
    title: "Math & chemistry",
    desc: "KaTeX for inline and block math, plus mhchem for equations, ions, and isotopes.",
    kbd: "$ … $",
  },
  {
    img: iconDiagram,
    title: "Mermaid diagrams",
    desc: "Flowcharts, sequence, class, state, gantt, ER, and mindmaps render live in the preview.",
    kbd: "```mermaid",
  },
  {
    img: iconSlash,
    title: "Slash commands",
    desc: "Type / for headings, lists, tables, math, callouts, and more. No syntax to memorize.",
    kbd: "/",
  },
  {
    img: iconLinkPages,
    title: "Wikilinks & outline",
    desc: "[[other-file]] links resolve in the folder, with an outline pane that follows your cursor.",
    kbd: "[[ ]]",
  },
  {
    img: iconPalette,
    title: "Command palette",
    desc: "Jump to any command, file, heading, or toggle. Find & Replace with regex too.",
    kbd: "Ctrl+P",
  },
  {
    img: iconMoonSun,
    title: "Themes & typography",
    desc: "Four themes, five fonts, three sizes, plus focus and typewriter modes.",
    kbd: "4 themes",
  },
  {
    img: iconBolt,
    title: "Native & private",
    desc: "Built on Tauri + Rust: small, fast, offline. No accounts, no tracking, files stay local.",
    kbd: "Tauri",
  },
];
---

<section id="features" class="relative py-24 md:py-32">
  <div class="mx-auto max-w-5xl px-5">
    <div class="max-w-2xl" data-reveal>
      <p class="mono-label"><span class="tok-mark">##</span> features</p>
      <h2 class="font-serif-display mt-3 text-[clamp(2.2rem,5vw,3.5rem)]">
        Power features, none of the setup.
      </h2>
      <p class="mt-4 text-lg text-fg-muted">
        A focused writing surface with the power features pros expect, and a few you won't find
        elsewhere.
      </p>
    </div>

    <!-- Big-icon card grid: the illustrated icon set carries the section -->
    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {rows.map((r) => (
        <article class="feature-card card flex flex-col p-6" data-reveal>
          <div class="flex items-start justify-between gap-3">
            <Image
              src={r.img}
              alt=""
              aria-hidden="true"
              widths={[128, 256]}
              sizes="64px"
              class="feature-icon h-16 w-16 shrink-0 select-none object-contain"
            />
            <span class={`kbd ${r.accent === "cyan" ? "!text-cyan" : ""}`}>{r.kbd}</span>
          </div>
          <h3 class="mt-4 font-semibold tracking-tight">{r.title}</h3>
          <p class="mt-1.5 text-[15px] leading-relaxed text-fg-muted">{r.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* Gentle lift + icon wiggle on hover; the icons do the personality work */
  .feature-card {
    transition: transform 0.25s var(--ease-out-expo), box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .feature-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--color-brand) 35%, var(--color-line));
    box-shadow: 0 18px 40px -22px rgba(43, 36, 32, 0.3);
  }
  .feature-icon {
    transition: transform 0.25s var(--ease-out-expo);
  }
  .feature-card:hover .feature-icon {
    transform: rotate(-4deg) scale(1.08);
  }
  @media (prefers-reduced-motion: reduce) {
    .feature-card,
    .feature-icon {
      transition: none;
    }
    .feature-card:hover,
    .feature-card:hover .feature-icon {
      transform: none;
    }
  }
</style>
